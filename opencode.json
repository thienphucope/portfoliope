{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "llamacpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama.cpp local think",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1",
        "apiKey": "sk-no-key-required",
        "timeout": 900000,
        "chunkTimeout": 120000
      },
      "models": {
        "qwen": {
          "name": "Qwen 3.5 35B A3B (no_think)",
          "limit": {
            "context": 65536,
            "output": 8192
          }
        }
      }
    }
  },
  "model": "qwen",
  "small_model": "qwen",
  "permission": {
    "edit": "ask",
    "bash": "ask"
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**",
      ".next/**",
      "coverage/**"
    ]
  }
}